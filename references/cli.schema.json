{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subagent latest JSONL line",
  "oneOf": [
    {"$ref": "#/$defs/Agent"},
    {"$ref": "#/$defs/AgentListItem"},
    {"$ref": "#/$defs/AgentRenamed"},
    {"$ref": "#/$defs/Message"},
    {"$ref": "#/$defs/MessageSent"},
    {"$ref": "#/$defs/Event"},
    {"$ref": "#/$defs/Error"},
    {"$ref": "#/$defs/DaemonRunning"},
    {"$ref": "#/$defs/DaemonStopping"},
    {"$ref": "#/$defs/SideCreated"},
    {"$ref": "#/$defs/Side"},
    {"$ref": "#/$defs/SideListItem"},
    {"$ref": "#/$defs/SideDeleted"},
    {"$ref": "#/$defs/ContextMeta"},
    {"$ref": "#/$defs/ModelMessage"},
    {"$ref": "#/$defs/AgentDeleted"},
    {"$ref": "#/$defs/Config"},
    {"$ref": "#/$defs/ConfigValue"}
  ],
  "$defs": {
    "Timestamp": {"type": "string", "format": "date-time"},
    "NullableTimestamp": {
      "oneOf": [{"$ref": "#/$defs/Timestamp"}, {"type": "null"}]
    },
    "Agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type", "id", "dir", "mode", "advisory_readonly", "model",
        "status", "spawned_at", "last_message_at", "run_started_at", "updated_at",
        "finished_at", "stopped_at", "failed_at", "deadline_at", "run_number",
        "stop_reason", "last_error"
      ],
      "properties": {
        "type": {"const": "agent"},
        "id": {"type": "string", "pattern": "^agt_[0-9A-HJKMNP-TV-Z]{26}$"},
        "dir": {"type": "string"},
        "mode": {"enum": ["readonly", "write"]},
        "advisory_readonly": {"type": "boolean"},
        "model": {"type": "string", "minLength": 1},
        "status": {"enum": ["working", "finished", "stopped", "failed"]},
        "spawned_at": {"$ref": "#/$defs/Timestamp"},
        "last_message_at": {"$ref": "#/$defs/Timestamp"},
        "run_started_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "finished_at": {"$ref": "#/$defs/NullableTimestamp"},
        "stopped_at": {"$ref": "#/$defs/NullableTimestamp"},
        "failed_at": {"$ref": "#/$defs/NullableTimestamp"},
        "deadline_at": {"$ref": "#/$defs/NullableTimestamp"},
        "run_number": {"type": "integer", "minimum": 1},
        "stop_reason": {
          "oneOf": [
            {"enum": ["user_request", "wall_time", "daemon_shutdown", "daemon_interrupted"]},
            {"type": "null"}
          ]
        },
        "last_error": {"type": ["string", "null"]}
      }
    },
    "AgentListItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type", "id", "name", "status", "dir", "mode", "spawned_at",
        "last_message_at", "updated_at", "run_number", "working_sides"
      ],
      "properties": {
        "type": {"const": "agent_list_item"},
        "id": {"type": "string", "pattern": "^agt_[0-9A-HJKMNP-TV-Z]{26}$"},
        "name": {"type": "string", "minLength": 4, "maxLength": 40},
        "status": {"enum": ["working", "finished", "stopped", "failed"]},
        "dir": {"type": "string"},
        "mode": {"enum": ["readonly", "write"]},
        "spawned_at": {"$ref": "#/$defs/Timestamp"},
        "last_message_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "run_number": {"type": "integer", "minimum": 1},
        "working_sides": {"type": "integer", "minimum": 0, "maximum": 2}
      }
    },
    "AgentRenamed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "name", "renamed_at"],
      "properties": {
        "type": {"const": "agent_renamed"},
        "id": {"type": "string", "pattern": "^agt_"},
        "name": {"type": "string", "minLength": 4, "maxLength": 40},
        "renamed_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type", "id", "agent_id", "content", "status", "sent_at",
        "delivered_at", "cancelled_at"
      ],
      "properties": {
        "type": {"const": "message"},
        "id": {"type": "string", "pattern": "^msg_[0-9A-HJKMNP-TV-Z]{26}$"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "content": {"type": "string"},
        "status": {"enum": ["pending", "delivered", "cancelled"]},
        "sent_at": {"$ref": "#/$defs/Timestamp"},
        "delivered_at": {"$ref": "#/$defs/NullableTimestamp"},
        "cancelled_at": {"$ref": "#/$defs/NullableTimestamp"}
      }
    },
    "MessageSent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message_id", "agent_id", "status", "sent_at"],
      "properties": {
        "type": {"const": "message_sent"},
        "message_id": {"type": "string", "pattern": "^msg_"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "status": {"const": "queued"},
        "sent_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "EventBase": {
      "type": "object",
      "required": ["event_id", "agent_id", "sequence", "timestamp", "type", "data"],
      "properties": {
        "event_id": {"type": "string", "pattern": "^evt_"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "side_id": {"type": "string", "pattern": "^side_"},
        "sequence": {"type": "integer", "minimum": 1},
        "timestamp": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Event": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "system_message"},
                "data": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["content"],
                  "properties": {"content": {"type": "string"}}
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "user_message"},
                "data": {
                  "oneOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["content", "source"],
                      "properties": {
                        "content": {"type": "string"},
                        "source": {"const": "spawn"}
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["content", "source"],
                      "properties": {
                        "content": {"type": "string"},
                        "source": {"const": "create"}
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["content", "source", "message_id"],
                      "properties": {
                        "content": {"type": "string"},
                        "source": {"const": "send"},
                        "message_id": {"type": "string", "pattern": "^msg_"}
                      }
                    }
                  ]
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "assistant_message"},
                "data": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["content", "usage"],
                  "properties": {
                    "content": {"type": "string"},
                    "usage": {"type": ["object", "null"]}
                  }
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "reasoning"},
                "data": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["content"],
                  "properties": {"content": {"type": "string"}}
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "tool_call"},
                "data": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["tool_call_id", "name", "arguments"],
                  "properties": {
                    "tool_call_id": {"type": "string"},
                    "name": {"type": "string"},
                    "arguments": {"type": "string"}
                  }
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "tool_result"},
                "data": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["tool_call_id", "name", "result"],
                  "properties": {
                    "tool_call_id": {"type": "string"},
                    "name": {"type": "string"},
                    "result": {"$ref": "#/$defs/ToolResult"}
                  }
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "lifecycle"},
                "data": {
                  "oneOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["status", "reason"],
                      "properties": {
                        "status": {"const": "working"},
                        "reason": {"const": "spawned"}
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["status", "reason"],
                      "properties": {
                        "status": {"const": "working"},
                        "reason": {"const": "created"}
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["status", "reason", "run_number"],
                      "properties": {
                        "status": {"const": "working"},
                        "reason": {"const": "resumed"},
                        "run_number": {"type": "integer", "minimum": 2}
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["status", "reason", "deadline_at"],
                      "properties": {
                        "status": {"const": "working"},
                        "reason": {"const": "deadline_updated"},
                        "deadline_at": {"$ref": "#/$defs/Timestamp"}
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["status"],
                      "properties": {"status": {"const": "finished"}}
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["status", "reason"],
                      "properties": {
                        "status": {"const": "stopped"},
                        "reason": {
                          "enum": [
                            "user_request", "wall_time",
                            "daemon_shutdown", "daemon_interrupted", "parent_deleted"
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          ],
          "unevaluatedProperties": false
        },
        {
          "allOf": [
            {"$ref": "#/$defs/EventBase"},
            {
              "properties": {
                "type": {"const": "error"},
                "data": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["status", "error"],
                  "properties": {
                    "status": {"const": "failed"},
                    "error": {"type": "string"}
                  }
                }
              }
            }
          ],
          "unevaluatedProperties": false
        }
      ]
    },
    "ToolFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "code", "error"],
      "properties": {
        "ok": {"const": false},
        "code": {"const": "tool_error"},
        "error": {"type": "string"}
      }
    },
    "Preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "head_bytes", "tail_bytes", "total_bytes", "truncated"],
      "properties": {
        "content": {"type": "string"},
        "head_bytes": {"type": "integer", "minimum": 0},
        "tail_bytes": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0},
        "truncated": {"type": "boolean"}
      }
    },
    "ToolResult": {
      "oneOf": [
        {"$ref": "#/$defs/ToolFailure"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "path", "offset", "lines", "truncated"],
          "properties": {
            "ok": {"const": true},
            "path": {"type": "string"},
            "offset": {"type": "integer", "minimum": 1},
            "lines": {"type": "array", "items": {"type": "string"}},
            "truncated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "root", "paths", "truncated"],
          "properties": {
            "ok": {"const": true},
            "root": {"type": "string"},
            "paths": {"type": "array", "items": {"type": "string"}},
            "truncated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "root", "matches", "truncated"],
          "properties": {
            "ok": {"const": true},
            "root": {"type": "string"},
            "matches": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path", "line", "text"],
                "properties": {
                  "path": {"type": "string"},
                  "line": {"type": "integer", "minimum": 1},
                  "text": {"type": "string"}
                }
              }
            },
            "truncated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "path", "bytes"],
          "properties": {
            "ok": {"const": true},
            "path": {"type": "string"},
            "bytes": {"type": "integer", "minimum": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "path", "replacements"],
          "properties": {
            "ok": {"const": true},
            "path": {"type": "string"},
            "replacements": {"type": "integer", "minimum": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "changed_files"],
          "properties": {
            "ok": {"const": true},
            "changed_files": {"type": "array", "items": {"type": "string"}}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "status", "exit_code", "output", "output_ref", "truncated"],
          "properties": {
            "ok": {"const": true},
            "status": {"const": "completed"},
            "exit_code": {"const": 0},
            "output": {"$ref": "#/$defs/Preview"},
            "output_ref": {"type": "string", "pattern": "^out_"},
            "truncated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "status", "terminal_id", "output", "output_ref", "truncated"],
          "properties": {
            "ok": {"const": true},
            "status": {"const": "running"},
            "terminal_id": {"type": "string", "pattern": "^term_"},
            "output": {"$ref": "#/$defs/Preview"},
            "output_ref": {"type": "string", "pattern": "^out_"},
            "truncated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ok", "terminal_id", "status", "exit_code", "output",
            "output_ref", "next_offset", "truncated"
          ],
          "properties": {
            "ok": {"type": "boolean"},
            "terminal_id": {"type": "string", "pattern": "^term_"},
            "status": {"enum": ["running", "completed"]},
            "exit_code": {"type": ["integer", "null"]},
            "output": {"type": "string"},
            "output_ref": {"type": "string", "pattern": "^out_"},
            "next_offset": {"type": "integer", "minimum": 0},
            "truncated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "terminals", "count", "limit"],
          "properties": {
            "ok": {"const": true},
            "terminals": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["terminal_id", "command", "cwd", "pid", "output_ref"],
                "properties": {
                  "terminal_id": {"type": "string", "pattern": "^term_"},
                  "command": {"type": "string"},
                  "cwd": {"type": "string"},
                  "pid": {"type": "integer", "minimum": 1},
                  "output_ref": {"type": "string", "pattern": "^out_"}
                }
              }
            },
            "count": {"type": "integer", "minimum": 0, "maximum": 8},
            "limit": {"const": 8}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "terminated"],
          "properties": {
            "ok": {"const": true},
            "terminated": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok"],
          "properties": {"ok": {"const": true}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "output_ref", "offset", "next_offset", "content", "eof"],
          "properties": {
            "ok": {"const": true},
            "output_ref": {"type": "string", "pattern": "^out_"},
            "offset": {"type": "integer", "minimum": 0},
            "next_offset": {"type": "integer", "minimum": 0},
            "content": {"type": "string"},
            "eof": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "path", "mime_type", "bytes", "note"],
          "properties": {
            "ok": {"const": true},
            "path": {"type": "string"},
            "mime_type": {"type": "string", "pattern": "^image/"},
            "bytes": {"type": "integer", "minimum": 0, "maximum": 5242880},
            "note": {"const": "image attached in the next model-visible message"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ok", "status", "exit_code", "output", "output_ref", "truncated"],
          "properties": {
            "ok": {"const": false},
            "status": {"const": "completed"},
            "exit_code": {"type": "integer"},
            "output": {"$ref": "#/$defs/Preview"},
            "output_ref": {"type": "string", "pattern": "^out_"},
            "truncated": {"type": "boolean"}
          }
        }
      ]
    },
    "Error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "code", "message", "details", "retryable"],
      "properties": {
        "type": {"const": "error"},
        "code": {
          "enum": [
            "daemon_unavailable", "daemon_already_running", "agent_not_found",
            "event_not_found", "message_not_found", "side_not_found", "invalid_argument",
            "file_too_large", "capacity_exceeded", "conflict", "timeout",
            "api_error", "internal_error", "cli_error"
          ]
        },
        "message": {"type": "string"},
        "details": {"type": "object"},
        "retryable": {"type": "boolean"}
      }
    },
    "DaemonRunning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type", "status", "pid", "socket", "working_agents",
        "max_agents", "model", "base_url", "web_ui_url"
      ],
      "properties": {
        "type": {"const": "daemon"},
        "status": {"const": "running"},
        "pid": {"type": "integer", "minimum": 1},
        "socket": {"type": "string"},
        "working_agents": {"type": "integer", "minimum": 0},
        "max_agents": {"type": "integer", "minimum": 0},
        "model": {"type": "string"},
        "base_url": {"type": "string"},
        "web_ui_url": {"type": ["string", "null"]}
      }
    },
    "DaemonStopping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "working_agents"],
      "properties": {
        "type": {"const": "daemon"},
        "status": {"const": "stopping"},
        "working_agents": {"type": "integer", "minimum": 0}
      }
    },
    "SideCreated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "agent_id", "status", "created_at"],
      "properties": {
        "type": {"const": "side_created"},
        "id": {"type": "string", "pattern": "^side_"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "status": {"const": "working"},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Side": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type", "id", "agent_id", "status", "question", "answer", "model",
        "mode", "parent_mode", "created_at", "run_started_at", "updated_at",
        "finished_at", "stopped_at", "failed_at", "deadline_at",
        "inherited_context_messages", "tool_calls", "stop_reason", "last_error"
      ],
      "properties": {
        "type": {"const": "side"},
        "id": {"type": "string", "pattern": "^side_"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "status": {"enum": ["working", "finished", "stopped", "failed"]},
        "question": {"type": "string"},
        "answer": {"type": ["string", "null"]},
        "model": {"type": "string"},
        "mode": {"const": "readonly"},
        "parent_mode": {"enum": ["readonly", "write"]},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "run_started_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "finished_at": {"$ref": "#/$defs/NullableTimestamp"},
        "stopped_at": {"$ref": "#/$defs/NullableTimestamp"},
        "failed_at": {"$ref": "#/$defs/NullableTimestamp"},
        "deadline_at": {"$ref": "#/$defs/NullableTimestamp"},
        "inherited_context_messages": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "stop_reason": {"type": ["string", "null"]},
        "last_error": {"type": ["string", "null"]}
      }
    },
    "SideListItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "agent_id", "status", "question_preview", "created_at", "updated_at", "tool_calls"],
      "properties": {
        "type": {"const": "side_list_item"},
        "id": {"type": "string", "pattern": "^side_"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "status": {"enum": ["working", "finished", "stopped", "failed"]},
        "question_preview": {"type": "string", "maxLength": 200},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "tool_calls": {"type": "integer", "minimum": 0}
      }
    },
    "SideDeleted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {"const": "side_deleted"},
        "id": {"type": "string", "pattern": "^side_"}
      }
    },
    "ContextMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "agent_id", "message_count", "compacted_at"],
      "properties": {
        "type": {"const": "context_meta"},
        "agent_id": {"type": "string", "pattern": "^agt_"},
        "message_count": {"type": "integer", "minimum": 0},
        "compacted_at": {"$ref": "#/$defs/NullableTimestamp"}
      }
    },
    "ModelMessage": {
      "type": "object",
      "required": ["role"],
      "properties": {
        "role": {"enum": ["system", "user", "assistant", "tool"]},
        "content": {},
        "tool_calls": {"type": "array"},
        "tool_call_id": {"type": "string"}
      },
      "additionalProperties": true
    },
    "AgentDeleted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {

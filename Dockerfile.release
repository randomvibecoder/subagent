FROM rust:1.95-alpine AS builder
RUN apk add --no-cache musl-dev
WORKDIR /src
COPY Cargo.toml Cargo.lock ./

RUN mkdir src \
    && printf 'fn main() {}\n' > src/main.rs \
    && cargo build --locked --release \
    && cargo clean -p subagent \
    && rm -rf src

COPY src ./src
RUN cargo clean -p subagent && touch src/*.rs && cargo build --locked --release

FROM scratch AS artifact
COPY --from=builder /src/target/release/subagent /subagent

FROM rust:1.95-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY Cargo.toml Cargo.lock ./

# Cache dependency compilation independently from changing project sources.
RUN mkdir src \
    && printf 'fn main() {}\n' > src/main.rs \
    && cargo test --locked --no-run \
    && cargo clean -p subagent \
    && rm -rf src

COPY src ./src
COPY tests ./tests

RUN cargo clean -p subagent && cargo test --locked
RUN cargo build --locked

ENV SUBAGENT_BIN=/workspace/target/debug/subagent
CMD ["bash", "tests/e2e.sh"]
